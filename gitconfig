[user]
    name=Niklas Claesson
    email=nicke.claesson@gmail.com
[core]
	excludesfile = /home/niklas/.gitignore

[color]
    branch = auto
    diff = auto
    status = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[branch "develop"]
    remote = origin
    merge = refs/heads/develop
[alias]
	co = checkout
    br = branch
    ci = commit
    st = status
